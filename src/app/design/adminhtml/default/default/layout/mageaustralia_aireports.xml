<?xml version="1.0"?>
<layout>
    <adminhtml_aireports_ask>
        <reference name="head">
            <action method="addCss"><name>AiReports/ai-reports.css</name></action>
            <action method="addItem"><type>skin_js</type><name>AiReports/vendor/chart.umd.min.js</name></action>
            <action method="addItem"><type>skin_js</type><name>AiReports/ai-reports.js</name></action>
        </reference>
        <reference name="content">
            <block type="aireports/adminhtml_ask" name="aireports.ask" template="mageaustralia/aireports/ask.phtml"/>
        </reference>
    </adminhtml_aireports_ask>

    <adminhtml_aireports_saved>
        <reference name="content">
            <block type="aireports/adminhtml_saved" name="aireports.saved"/>
        </reference>
    </adminhtml_aireports_saved>

    <adminhtml_aireports_savedGrid>
        <block type="core/text_list" name="root" output="toHtml">
            <block type="aireports/adminhtml_saved_grid" name="aireports.saved.grid"/>
        </block>
    </adminhtml_aireports_savedGrid>

    <adminhtml_aireports_viewSaved>
        <reference name="head">
            <action method="addCss"><name>AiReports/ai-reports.css</name></action>
            <action method="addItem"><type>skin_js</type><name>AiReports/vendor/chart.umd.min.js</name></action>
            <action method="addItem"><type>skin_js</type><name>AiReports/ai-reports.js</name></action>
        </reference>
        <reference name="content">
            <block type="aireports/adminhtml_savedView" name="aireports.savedView" template="mageaustralia/aireports/saved_view.phtml"/>
        </reference>
    </adminhtml_aireports_viewSaved>
</layout>
